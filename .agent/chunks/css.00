:root {
  --iyo-bg: #050505;
  --iyo-panel: #0c0c0b;
  --iyo-text: #f1efe9;
  --iyo-muted: rgba(241, 239, 233, 0.56);
  --iyo-faint: rgba(241, 239, 233, 0.34);
  --iyo-line: rgba(255, 255, 255, 0.1);
  --iyo-line-strong: rgba(255, 255, 255, 0.18);
  --iyo-ease: cubic-bezier(0.16, 1, 0.3, 1);
}

html,
body {
  margin: 0;
  background: var(--iyo-bg);
  color: var(--iyo-text);
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button,
input,
select {
  font: inherit;
}

button {
  color: inherit;
}

.p5 {
  --p5-hue: 36;
  --p5-intensity: 0.4;
  --p5-daylight: 0.4;
  --p5-scroll: 0;
  min-height: 100vh;
  color: var(--iyo-text);
  background: var(--iyo-bg);
  overflow-x: clip;
  isolation: isolate;
}

.p5-atmosphere,
.p5-atmosphere::before,
.p5-atmosphere::after {
  position: fixed;
  inset: 0;
  pointer-events: none;
}

.p5-atmosphere {
  z-index: 0;
  background:
    radial-gradient(circle at calc(66% - var(--p5-scroll) * 12%) 36%, hsla(var(--p5-hue), 55%, 48%, calc(var(--p5-intensity) * 0.18)), transparent 34%),
    radial-gradient(circle at 14% 14%, rgba(89, 107, 126, 0.08), transparent 32%),
    linear-gradient(135deg, rgba(255, 255, 255, calc(var(--p5-daylight) * 0.025)), transparent 46%),
    #050505;
  transition: background 900ms var(--iyo-ease);
}

.p5-atmosphere::before {
  content: "";
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.018) 1px, transparent 1px), linear-gradient(rgba(255, 255, 255, 0.014) 1px, transparent 1px);
  background-size: 72px 72px;
  mask-image: radial-gradient(circle at 62% 42%, black, transparent 72%);
  opacity: 0.32;
}

.p5-atmosphere::after {
  content: "";
  background: radial-gradient(circle, transparent 38%, rgba(0, 0, 0, 0.72) 100%);
}

.p5-atmosphere > span {
  position: absolute;
  width: 34vw;
  aspect-ratio: 1;
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.1;
  background: hsl(var(--p5-hue) 55% 46%);
  animation: p5-drift 16s ease-in-out infinite alternate;
}

.p5-atmosphere > span:first-child { top: 8%; right: 8%; }
.p5-atmosphere > span:last-child { bottom: 2%; left: -8%; animation-delay: -8s; }

@keyframes p5-drift {
  to { transform: translate3d(4vw, 3vh, 0) scale(1.12); }
}

.p5-global-nav {
  position: fixed;
  top: max(16px, env(safe-area-inset-top));
  left: clamp(16px, 3vw, 48px);
  right: clamp(16px, 3vw, 48px);
  z-index: 80;
  height: 58px;
  display: grid;
  grid-template-columns: minmax(120px, 1fr) auto minmax(220px, 1fr);
  align-items: center;
  gap: 24px;
  padding: 0 12px;
  border: 1px solid var(--iyo-line);
  border-radius: 22px;
  background: rgba(8, 8, 8, 0.67);
  box-shadow: 0 18px 60px rgba(0, 0, 0, 0.32);
  backdrop-filter: blur(24px) saturate(1.1);
}

.p5-brand,
.p5-nav-links button,
.p5-room-button,
.p5-icon-button,
.p5-profile {
  border: 0;
  background: transparent;
  cursor: pointer;
}

.p5-brand {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  justify-self: start;
}

.p5-brand > span {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #f2efe8;
  box-shadow: 0 0 24px rgba(255, 255, 255, 0.35);
}

.p5-brand strong { font-size: 0.9rem; font-weight: 560; letter-spacing: 0.02em; }

.p5-nav-links { display: flex; align-items: center; gap: 3px; padding: 4px; border-radius: 16px; background: rgba(255, 255, 255, 0.035); }
.p5-nav-links button { min-height: 38px; padding: 0 15px; border-radius: 12px; color: var(--iyo-muted); font-size: 0.82rem; transition: 220ms ease; }
.p5-nav-links button:hover,
.p5-nav-links button[aria-current="page"] { color: var(--iyo-text); background: rgba(255, 255, 255, 0.09); }

.p5-nav-actions { display: flex; align-items: center; justify-content: flex-end; gap: 8px; }
.p5-room-button { display: inline-flex; align-items: center; gap: 8px; min-height: 40px; padding: 0 13px; border-radius: 13px; color: var(--iyo-muted); background: rgba(255, 255, 255, 0.045); }
.p5-icon-button,
.p5-profile { width: 40px; height: 40px; border-radius: 50%; display: grid; place-items: center; background: rgba(255, 255, 255, 0.045); }
.p5-profile { font-size: 0.68rem; letter-spacing: 0.06em; }

.p5-room-menu {
  position: absolute;
  top: 66px;
  right: 0;
  width: min(300px, calc(100vw - 32px));
  padding: 8px;
  border: 1px solid var(--iyo-line);
  border-radius: 18px;
  background: rgba(11, 11, 10, 0.96);
  box-shadow: 0 30px 90px rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(28px);
}
.p5-room-menu[hidden] { display: none; }
.p5-room-menu button { width: 100%; min-height: 50px; padding: 0 12px; border: 0; border-radius: 12px; background: transparent; display: flex; align-items: center; justify-content: space-between; text-align: left; cursor: pointer; }
.p5-room-menu button:hover { background: rgba(255, 255, 255, 0.07); }
.p5-room-menu small { color: var(--iyo-muted); }

.p5-stage {
  position: fixed;
  z-index: 12;
  top: 90px;
  right: 3vw;
  width: min(58vw, 900px);
