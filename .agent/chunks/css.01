  height: calc(100vh - 120px);
  pointer-events: none;
  transition: width 620ms var(--iyo-ease), right 620ms var(--iyo-ease), opacity 320ms ease;
}
.p5-stage canvas { width: 100%; height: 100%; display: block; filter: drop-shadow(0 44px 46px rgba(0, 0, 0, 0.52)); }
.p5[data-mode="detail"] .p5-stage { width: min(68vw, 1040px); right: 28vw; pointer-events: auto; }
.p5[data-section="settings"] .p5-stage { width: 42vw; right: 4vw; }
.p5[data-section="alarm"] .p5-stage { opacity: 0.62; }

.p5-surface { position: relative; z-index: 20; min-height: 100vh; }
.p5-surface[hidden] { display: none; }

.p5-hero {
  min-height: 100svh;
  position: relative;
  display: grid;
  align-items: center;
  padding: 110px clamp(24px, 6vw, 92px) 70px;
  box-sizing: border-box;
}

.p5-hero-copy-panel { width: min(39vw, 570px); transform: translateY(calc(var(--p5-scroll) * -34px)); opacity: calc(1 - var(--p5-scroll) * 0.74); }
.p5-eyebrow { margin: 0 0 18px; color: var(--iyo-muted); font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; }
.p5-hero h1,
.p5-room-copy h1,
.p5-page-head h1 { margin: 0; font-size: clamp(3.4rem, 7.1vw, 8.4rem); line-height: 0.88; letter-spacing: -0.075em; font-weight: 470; text-wrap: balance; }
.p5-hero-status { margin: 24px 0 30px; font-size: clamp(1rem, 1.5vw, 1.35rem); color: var(--iyo-muted); }
.p5-primary-action { min-height: 48px; padding: 0 20px; border: 1px solid rgba(255, 255, 255, 0.22); border-radius: 999px; background: rgba(255, 255, 255, 0.1); cursor: pointer; transition: 220ms ease; }
.p5-primary-action:hover { background: var(--iyo-text); color: #080808; transform: translateY(-2px); }

.p5-hero-index { position: absolute; right: clamp(26px, 5vw, 78px); bottom: 56px; display: flex; align-items: center; gap: 12px; color: var(--iyo-muted); font-variant-numeric: tabular-nums; }
.p5-hero-index i { width: 54px; height: 1px; background: var(--iyo-line-strong); }
.p5-scroll-cue { position: absolute; left: clamp(24px, 6vw, 92px); bottom: 46px; display: flex; align-items: center; gap: 14px; color: var(--iyo-faint); font-size: 0.72rem; letter-spacing: 0.11em; text-transform: uppercase; }
.p5-scroll-cue i { width: 52px; height: 1px; background: var(--iyo-line); }

.p5-device-rail { position: relative; z-index: 30; margin-top: -116px; padding-bottom: 36px; }
.p5-hero-carousel { min-height: 118px; grid-auto-columns: min(25vw, 300px); gap: 14px; padding: 0 clamp(24px, 6vw, 92px); }
.p5-hero-card { min-height: 112px; transform: none; opacity: 0.48; }
.p5-hero-card[aria-selected="true"] { opacity: 1; transform: none; }
.p5-hero-hit { min-height: 112px; grid-template-columns: 60px 1fr; grid-template-rows: 1fr; align-items: center; gap: 14px; padding: 12px 16px; box-sizing: border-box; border: 1px solid var(--iyo-line); border-radius: 22px; background: rgba(255, 255, 255, 0.035); backdrop-filter: blur(18px); }
.p5-hero-card[aria-selected="true"] .p5-hero-hit { background: rgba(255, 255, 255, 0.085); border-color: var(--iyo-line-strong); }
.p5-hero-host { min-height: 58px; width: 58px; border-radius: 18px; display: grid; place-items: center; background: rgba(255, 255, 255, 0.06); }
.p5-hero-copy { padding: 0; gap: 4px; min-width: 0; }
.p5-hero-copy .p5-label { font-size: 0.62rem; color: var(--iyo-faint); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.p5-hero-copy strong { font-size: 1rem; letter-spacing: -0.025em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.p5-hero-copy > span:last-child { font-size: 0.78rem; color: var(--iyo-muted); }

.p5-device-glyph { position: relative; display: inline-grid; place-items: center; width: 44px; height: 44px; border-radius: 15px; background: rgba(255, 255, 255, 0.07); }
.p5-device-glyph::before,
.p5-device-glyph::after { content: ""; position: absolute; border: 1px solid rgba(255, 255, 255, 0.72); }
.p5-device-glyph[data-category="light"]::before,
[data-category="light"] .p5-device-glyph::before { width: 16px; height: 19px; border-radius: 50% 50% 42% 42%; top: 9px; }
.p5-device-glyph[data-category="light"]::after,
[data-category="light"] .p5-device-glyph::after { width: 10px; height: 4px; border-width: 1px 0; bottom: 9px; }
.p5-device-glyph[data-category="climate"]::before,
[data-category="climate"] .p5-device-glyph::before { width: 22px; height: 22px; border-radius: 50%; }
.p5-device-glyph[data-category="climate"]::after,
[data-category="climate"] .p5-device-glyph::after { width: 4px; height: 4px; border-radius: 50%; background: currentColor; }
.p5-device-glyph[data-category="cover"]::before,
[data-category="cover"] .p5-device-glyph::before { width: 21px; height: 23px; border-radius: 2px; background: repeating-linear-gradient(to bottom, transparent 0 4px, rgba(255,255,255,.4) 4px 5px); }
.p5-device-glyph[data-category="media"]::before,
[data-category="media"] .p5-device-glyph::before { width: 24px; height: 15px; border-radius: 2px; }
.p5-device-glyph[data-category="cleaning"]::before,
[data-category="cleaning"] .p5-device-glyph::before { width: 24px; height: 24px; border-radius: 50%; }
.p5-device-glyph[data-category="security"]::before,
[data-category="security"] .p5-device-glyph::before { width: 17px; height: 14px; border-radius: 3px; bottom: 9px; }
.p5-device-glyph[data-category="security"]::after,
[data-category="security"] .p5-device-glyph::after { width: 11px; height: 10px; border-radius: 9px 9px 0 0; top: 8px; border-bottom: 0; }
.p5-device-glyph[data-category="sensor"]::before,
[data-category="sensor"] .p5-device-glyph::before { width: 20px; height: 20px; border-radius: 50%; }
.p5-device-glyph[data-category="sensor"]::after,
[data-category="sensor"] .p5-device-glyph::after { width: 5px; height: 5px; border-radius: 50%; background: currentColor; }
.p5-device-glyph[data-category="appliance"]::before,
[data-category="appliance"] .p5-device-glyph::before { width: 21px; height: 24px; border-radius: 5px; }

.p5-lower-content,
.p5-room-content { position: relative; z-index: 25; padding: 100px clamp(24px, 6vw, 92px) 140px; background: linear-gradient(180deg, rgba(5, 5, 5, 0.15), #080808 180px); }
.p5-section-heading { display: grid; grid-template-columns: minmax(0, 1fr) minmax(240px, 0.42fr); gap: 40px; align-items: end; margin-bottom: 54px; }
.p5-section-heading h2 { margin: 0; font-size: clamp(2.7rem, 5.6vw, 6.2rem); line-height: 0.92; letter-spacing: -0.065em; font-weight: 470; }
.p5-section-heading > p { margin: 0; color: var(--iyo-muted); line-height: 1.6; }
.p5-summary-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
.p5-summary-card { min-height: 180px; padding: 22px; border: 1px solid var(--iyo-line); border-radius: 24px; background: rgba(255, 255, 255, 0.035); display: flex; flex-direction: column; align-items: flex-start; text-align: left; cursor: default; }
button.p5-summary-card { cursor: pointer; }
.p5-summary-card span,
.p5-summary-card small { color: var(--iyo-muted); }
.p5-summary-card strong { margin: auto 0 8px; font-size: clamp(1.65rem, 2.8vw, 2.7rem); letter-spacing: -0.045em; font-weight: 500; }
.p5-content-block { margin-top: 90px; }
.p5-block-title { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
.p5-block-title h3 { margin: 0; font-size: 1.45rem; font-weight: 500; letter-spacing: -0.03em; }
.p5-block-title span,
.p5-block-title button { color: var(--iyo-muted); }
.p5-block-title button { border: 0; background: transparent; cursor: pointer; }
.p5-scene-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
.p5-scene-card { min-height: 196px; padding: 20px; border: 1px solid var(--iyo-line); border-radius: 24px; background: rgba(255, 255, 255, 0.035); display: flex; flex-direction: column; align-items: flex-start; text-align: left; cursor: pointer; transition: 240ms ease; }
.p5-scene-card:hover { transform: translateY(-4px); background: rgba(255, 255, 255, 0.075); }
.p5-scene-card > span { width: 42px; height: 42px; border-radius: 50%; display: grid; place-items: center; background: rgba(255, 255, 255, 0.08); }
.p5-scene-card strong { margin-top: auto; font-size: 1.18rem; font-weight: 520; }
.p5-scene-card small { margin-top: 5px; color: var(--iyo-muted); }
.p5-room-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
.p5-room-card { min-height: 220px; padding: 22px; border: 1px solid var(--iyo-line); border-radius: 24px; background: linear-gradient(145deg, rgba(255,255,255,.055), rgba(255,255,255,.018)); display: flex; flex-direction: column; align-items: flex-start; text-align: left; cursor: pointer; }
.p5-room-card > span { color: var(--iyo-faint); font-size: 0.72rem; }
.p5-room-card strong { margin-top: auto; font-size: 1.8rem; letter-spacing: -0.045em; font-weight: 500; }
.p5-room-card small { margin-top: 6px; color: var(--iyo-muted); }
.p5-state-list { border-top: 1px solid var(--iyo-line); }
.p5-device-row { width: 100%; min-height: 78px; padding: 10px 0; border: 0; border-bottom: 1px solid var(--iyo-line); background: transparent; display: grid; grid-template-columns: 52px minmax(0, 1fr) auto; align-items: center; gap: 15px; text-align: left; cursor: pointer; }
.p5-device-row > span:nth-child(2) { display: grid; gap: 4px; }
.p5-device-row strong { font-weight: 500; }
.p5-device-row small,
.p5-device-row em { color: var(--iyo-muted); font-style: normal; }

.p5-room-hero { min-height: 86svh; padding: 130px clamp(24px, 6vw, 92px) 70px; box-sizing: border-box; display: grid; grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.6fr); align-items: end; gap: 40px; position: relative; }
.p5-room-copy { align-self: center; max-width: 48vw; }
.p5-room-copy p:last-child { color: var(--iyo-muted); margin-top: 22px; }
.p5-room-environment { display: grid; grid-template-columns: 1fr 1fr; align-self: end; border-top: 1px solid var(--iyo-line); }
.p5-room-environment > div { min-height: 92px; padding: 16px 0; border-bottom: 1px solid var(--iyo-line); display: grid; gap: 8px; }
.p5-room-environment > div:nth-child(odd) { border-right: 1px solid var(--iyo-line); padding-right: 18px; }
.p5-room-environment > div:nth-child(even) { padding-left: 18px; }
.p5-room-environment span { color: var(--iyo-muted); font-size: 0.72rem; }
.p5-room-environment strong { font-size: 1.3rem; font-weight: 500; }
.p5-room-featured { position: absolute; right: clamp(24px, 6vw, 92px); top: 150px; width: min(28vw, 360px); text-align: right; }
.p5-room-featured p { color: var(--iyo-muted); }
.p5-room-featured h2 { margin: 6px 0; font-size: clamp(2rem, 3vw, 3.7rem); line-height: .95; letter-spacing: -.055em; font-weight: 480; }
.p5-room-featured strong { color: var(--iyo-muted); font-weight: 450; }
.p5-room-featured button { display: block; margin: 18px 0 0 auto; min-height: 42px; padding: 0 16px; border: 1px solid var(--iyo-line-strong); border-radius: 999px; background: rgba(255,255,255,.06); cursor: pointer; }
.p5-room-tabs { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 24px; }
.p5-room-tabs button { min-height: 42px; padding: 0 16px; border: 1px solid var(--iyo-line); border-radius: 999px; background: transparent; color: var(--iyo-muted); white-space: nowrap; cursor: pointer; }
.p5-room-tabs button[aria-selected="true"] { color: #080808; background: var(--iyo-text); }
.p5-room-scenes { margin: 60px 0 90px; }
.p5-device-section { margin-top: 70px; }
.p5-device-card-grid,
.p5-alarm-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
.p5-device-card { min-height: 210px; padding: 20px; border: 1px solid var(--iyo-line); border-radius: 24px; background: rgba(255,255,255,.035); display: grid; grid-template-columns: auto 1fr; grid-template-rows: 1fr auto; gap: 16px; text-align: left; cursor: pointer; }
.p5-device-card > span:nth-child(2) { display: grid; align-content: end; gap: 4px; }
.p5-device-card small,
.p5-device-card em { color: var(--iyo-muted); font-style: normal; }
.p5-device-card strong { font-size: 1.35rem; font-weight: 500; letter-spacing: -.035em; }
.p5-device-card em { grid-column: 1 / -1; }

.p5-page-head { min-height: 58svh; padding: 150px clamp(24px, 6vw, 92px) 72px; box-sizing: border-box; max-width: 76vw; }
.p5-page-head h1 { font-size: clamp(3.5rem, 7vw, 8rem); }
.p5-page-head > p:last-child { max-width: 630px; color: var(--iyo-muted); line-height: 1.65; }

.p5-model-configurator { position: relative; z-index: 30; padding: 0 clamp(24px, 6vw, 92px) 140px; display: grid; grid-template-columns: minmax(220px, .36fr) minmax(520px, .9fr); gap: 16px; align-items: start; }
.p5-model-device-list,
.p5-model-form { border: 1px solid var(--iyo-line); border-radius: 26px; background: rgba(10,10,9,.78); backdrop-filter: blur(22px); }
.p5-model-device-list { padding: 8px; max-height: 680px; overflow-y: auto; }
.p5-model-device-list button { width: 100%; min-height: 72px; padding: 10px; border: 0; border-radius: 17px; background: transparent; display: flex; align-items: center; gap: 12px; text-align: left; cursor: pointer; }
.p5-model-device-list button[aria-current="true"] { background: rgba(255,255,255,.09); }
.p5-model-device-list button > span:last-child { display: grid; gap: 4px; }
.p5-model-device-list small { color: var(--iyo-muted); }
.p5-model-form { padding: 28px; display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
.p5-form-head { grid-column: 1 / -1; display: flex; justify-content: space-between; gap: 20px; padding-bottom: 24px; border-bottom: 1px solid var(--iyo-line); }
.p5-form-head p,
.p5-form-head span { color: var(--iyo-muted); }
.p5-form-head h2 { margin: 4px 0 8px; font-size: 2.4rem; letter-spacing: -.05em; font-weight: 500; }
.p5-model-badge { align-self: flex-start; padding: 8px 12px; border: 1px solid var(--iyo-line); border-radius: 999px; }
.p5-model-form label { display: grid; gap: 8px; color: var(--iyo-muted); font-size: .78rem; }
.p5-model-form select,
.p5-model-form input[type="url"] { width: 100%; min-height: 46px; box-sizing: border-box; padding: 0 12px; border: 1px solid var(--iyo-line); border-radius: 13px; background: rgba(255,255,255,.045); color: var(--iyo-text); }
.p5-model-form input[type="range"] { width: 100%; accent-color: var(--iyo-text); }
.p5-form-wide { grid-column: 1 / -1; }
.p5-upload { min-height: 78px; padding: 16px; box-sizing: border-box; border: 1px dashed var(--iyo-line-strong); border-radius: 16px; }
.p5-model-actions { display: flex; justify-content: flex-end; gap: 8px; padding-top: 14px; }
.p5-model-actions button { min-height: 44px; padding: 0 16px; border: 1px solid var(--iyo-line); border-radius: 999px; background: rgba(255,255,255,.045); cursor: pointer; }

.p5-alarm-head { min-height: 68svh; }
.p5-alarm-actions { display: flex; gap: 10px; margin-top: 28px; }
.p5-alarm-actions button { min-height: 46px; padding: 0 18px; border: 1px solid var(--iyo-line-strong); border-radius: 999px; background: rgba(255,255,255,.065); cursor: pointer; }
.p5-alarm-grid { padding: 0 clamp(24px, 6vw, 92px) 140px; }

