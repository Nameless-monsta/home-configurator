.p5-detail { position: fixed; inset: 0; z-index: 45; pointer-events: none; visibility: hidden; opacity: 0; transition: opacity 300ms ease, visibility 0s 300ms; }
.p5[data-mode="detail"] .p5-detail { pointer-events: none; visibility: visible; opacity: 1; transition-delay: 0s; }
.p5[data-mode="detail"] .p5-detail button,
.p5[data-mode="detail"] .p5-detail .p5-control-tray { pointer-events: auto; }
.p5[data-mode="detail"] .p5-surface { opacity: 0; visibility: hidden; }
.p5[data-mode="detail"] .p5-global-nav { opacity: .22; transform: translateY(-8px); pointer-events: none; }
.p5-global-nav { transition: opacity 300ms ease, transform 500ms var(--iyo-ease); }
.p5-detail-back { position: absolute; top: max(100px, calc(env(safe-area-inset-top) + 78px)); left: clamp(24px, 4vw, 64px); min-height: 44px; padding: 0 16px; border: 1px solid var(--iyo-line); border-radius: 999px; background: rgba(10,10,10,.62); backdrop-filter: blur(18px); cursor: pointer; }
.p5-detail-switcher { position: absolute; top: max(100px, calc(env(safe-area-inset-top) + 78px)); right: clamp(24px, 4vw, 64px); display: flex; gap: 6px; }
.p5-detail-switcher button { width: 44px; height: 44px; border: 1px solid var(--iyo-line); border-radius: 50%; background: rgba(10,10,10,.62); cursor: pointer; }
.p5-detail-identity { position: absolute; left: clamp(28px, 6vw, 92px); top: 31%; max-width: 30vw; }
.p5-detail-identity .p5-label { color: var(--iyo-muted); font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; }
.p5-detail-name { margin: 10px 0; font-size: clamp(3rem, 5.4vw, 6.6rem); line-height: .88; letter-spacing: -.07em; font-weight: 470; }
.p5-device-model { color: var(--iyo-muted); }
.p5-detail-readout-wrap { position: absolute; left: clamp(28px, 6vw, 92px); bottom: 26%; }
.p5-readout { display: flex; align-items: baseline; flex-wrap: wrap; gap: 10px; }
.p5-readout strong { font-size: clamp(2.5rem, 4.6vw, 5.5rem); font-weight: 470; letter-spacing: -.06em; }
.p5-readout span { color: var(--iyo-muted); }
.p5-readout-flag { padding: 5px 8px; border: 1px solid var(--iyo-line); border-radius: 999px; font-size: .7rem; }
.p5-confirm { margin-top: 8px; color: #f0b18e; }
.p5-detail-tray { position: absolute; left: clamp(28px, 6vw, 92px); right: auto; bottom: max(26px, env(safe-area-inset-bottom)); }
.p5-control-tray { width: min(520px, 38vw); margin: 0; border-color: var(--iyo-line); background: rgba(10,10,9,.76); color: var(--iyo-text); box-shadow: 0 24px 80px rgba(0,0,0,.4); }
.p5-control-row { background: rgba(255,255,255,.05); }
.p5-segmented { background: rgba(255,255,255,.05); }
.p5-segmented button[aria-pressed="true"] { background: rgba(255,255,255,.14); box-shadow: none; }
.p5-detail-context { position: absolute; right: clamp(24px, 4vw, 64px); bottom: 8vh; width: min(310px, 24vw); display: grid; gap: 10px; }
.p5-detail-context section { padding: 18px; border: 1px solid var(--iyo-line); border-radius: 20px; background: rgba(10,10,9,.62); backdrop-filter: blur(18px); }
.p5-detail-context dl { margin: 0; }
.p5-detail-context dl > div { display: flex; justify-content: space-between; gap: 10px; padding: 7px 0; border-bottom: 1px solid var(--iyo-line); }
.p5-detail-context dt { color: var(--iyo-muted); }
.p5-detail-context dd { margin: 0; }
.p5-detail-context strong,
.p5-detail-context small { display: block; }
.p5-detail-context small { margin-top: 6px; color: var(--iyo-muted); line-height: 1.45; }
.p5-detail-context button { margin-top: 13px; border: 0; background: transparent; padding: 0; text-decoration: underline; cursor: pointer; }
.p5-detail-context p:last-child { margin: 0; color: var(--iyo-muted); line-height: 1.5; }

.p5-search { position: fixed; inset: 0; z-index: 100; display: grid; place-items: start center; padding: max(90px, 12vh) 18px 30px; box-sizing: border-box; background: rgba(0,0,0,.72); backdrop-filter: blur(18px); }
.p5-search[hidden] { display: none; }
.p5-search-card { width: min(720px, 100%); padding: 22px; border: 1px solid var(--iyo-line); border-radius: 26px; background: #0b0b0a; box-shadow: 0 40px 120px rgba(0,0,0,.65); }
.p5-search-card > div:first-child { display: flex; justify-content: space-between; align-items: center; }
.p5-search-card h2 { margin: 0; font-weight: 500; letter-spacing: -.04em; }
.p5-search-card [data-p5-search-close] { width: 40px; height: 40px; border: 0; border-radius: 50%; background: rgba(255,255,255,.06); cursor: pointer; }
.p5-search-card input { width: 100%; height: 58px; margin: 20px 0 8px; padding: 0 16px; box-sizing: border-box; border: 1px solid var(--iyo-line); border-radius: 17px; background: rgba(255,255,255,.05); color: var(--iyo-text); font-size: 1.05rem; }

.p5-empty { color: var(--iyo-muted); }
.p5-sr { position: fixed; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
.p5 :focus-visible { outline: 2px solid rgba(255,255,255,.88); outline-offset: 3px; }

@media (max-width: 1120px) {
  .p5-global-nav { grid-template-columns: auto 1fr auto; }
  .p5-nav-links { justify-self: center; }
  .p5-room-button { display: none; }
  .p5-stage { width: 56vw; }
  .p5-hero-copy-panel { width: 45vw; }
  .p5-summary-grid,
  .p5-scene-grid,
  .p5-room-grid { grid-template-columns: repeat(2, 1fr); }
  .p5-device-card-grid,
  .p5-alarm-grid { grid-template-columns: repeat(2, 1fr); }
  .p5-model-configurator { grid-template-columns: 240px minmax(0, 1fr); }
  .p5-detail-context { display: none; }
  .p5[data-mode="detail"] .p5-stage { width: 64vw; right: 24vw; }
  .p5-detail-identity { max-width: 36vw; }
}

@media (max-width: 760px) {
  .p5-global-nav { top: max(10px, env(safe-area-inset-top)); left: 12px; right: 12px; height: 52px; padding: 0 8px; grid-template-columns: auto 1fr auto; gap: 8px; border-radius: 18px; }
  .p5-brand strong { display: none; }
  .p5-nav-links { justify-self: stretch; overflow-x: auto; }
  .p5-nav-links button { padding: 0 10px; min-height: 34px; font-size: .72rem; }
  .p5-nav-links button:nth-child(3) { display: none; }
  .p5-icon-button { display: none; }
  .p5-profile { width: 34px; height: 34px; }
  .p5-stage { top: 72px; right: -7vw; width: 108vw; height: 55svh; }
  .p5[data-mode="detail"] .p5-stage { top: 112px; right: -8vw; width: 116vw; height: 52svh; }
  .p5[data-section="settings"] .p5-stage { top: 92px; right: -12vw; width: 112vw; height: 42svh; }
  .p5-hero { min-height: 100svh; align-items: end; padding: 74px 20px 150px; }
  .p5-hero-copy-panel { width: 100%; opacity: 1; transform: none; }
  .p5-hero h1,
  .p5-room-copy h1,
  .p5-page-head h1 { font-size: clamp(3.2rem, 15vw, 5.4rem); }
  .p5-hero-status { margin: 14px 0 20px; }
  .p5-scroll-cue { left: 20px; bottom: 98px; }
  .p5-hero-index { right: 20px; bottom: 100px; }
  .p5-device-rail { margin-top: -92px; }
  .p5-hero-carousel { grid-auto-columns: 78vw; padding-inline: 20px; }
  .p5-lower-content,
  .p5-room-content { padding: 70px 20px 100px; }
  .p5-section-heading { grid-template-columns: 1fr; gap: 18px; }
  .p5-section-heading h2 { font-size: 3.2rem; }
  .p5-summary-grid,
  .p5-scene-grid,
  .p5-room-grid,
  .p5-device-card-grid,
  .p5-alarm-grid { grid-template-columns: 1fr; }
  .p5-summary-card { min-height: 142px; }
  .p5-scene-card { min-height: 155px; }
  .p5-room-card { min-height: 170px; }
  .p5-content-block { margin-top: 68px; }
  .p5-room-hero { min-height: 100svh; padding: 90px 20px 110px; display: flex; flex-direction: column; justify-content: flex-end; align-items: stretch; }
  .p5-room-copy { max-width: none; }
  .p5-room-featured { position: static; width: auto; text-align: left; margin-top: 24px; }
  .p5-room-featured button { margin-left: 0; }
  .p5-room-environment { width: 100%; margin-top: 26px; }
  .p5-page-head { min-height: 64svh; max-width: none; padding: 110px 20px 52px; }
  .p5-model-configurator { padding: 0 20px 100px; grid-template-columns: 1fr; }
  .p5-model-device-list { display: flex; max-height: none; overflow-x: auto; }
  .p5-model-device-list button { min-width: 210px; }
  .p5-model-form { grid-template-columns: 1fr; padding: 20px; }
  .p5-form-wide,
  .p5-form-head { grid-column: 1; }
  .p5-form-head { display: grid; }
  .p5-model-badge { justify-self: start; }
  .p5-alarm-grid { padding: 0 20px 100px; }
  .p5-detail-back { top: max(78px, calc(env(safe-area-inset-top) + 66px)); left: 16px; }
  .p5-detail-switcher { top: max(78px, calc(env(safe-area-inset-top) + 66px)); right: 16px; }
  .p5-detail-identity { top: auto; left: 20px; right: 20px; bottom: 31%; max-width: none; }
  .p5-detail-name { font-size: clamp(2.6rem, 13vw, 4.4rem); }
  .p5-detail-readout-wrap { left: 20px; bottom: 23%; }
  .p5-detail-tray { left: 16px; right: 16px; bottom: max(12px, env(safe-area-inset-bottom)); }
  .p5-control-tray { width: 100%; }
  .p5-control-summary { padding: 14px 18px; }
  .p5-search { padding-top: max(74px, 10vh); }
}

@media (max-width: 380px) {
  .p5-nav-links button { padding-inline: 8px; }
  .p5-nav-links button:nth-child(4) { display: none; }
  .p5-hero h1 { font-size: 3.15rem; }
  .p5-hero-carousel { grid-auto-columns: 84vw; }
}

@media (max-height: 560px) and (orientation: landscape) {
  .p5-stage { top: 64px; height: calc(100vh - 72px); width: 57vw; }
  .p5-hero { min-height: 620px; padding-top: 80px; }
  .p5-hero h1 { font-size: 3.6rem; }
  .p5-detail-identity { top: 32%; }
  .p5-detail-readout-wrap { bottom: 21%; }
  .p5-control-tray { width: 42vw; }
}

@media (prefers-reduced-motion: reduce) {
  .p5 *,
  .p5 *::before,
  .p5 *::after { scroll-behavior: auto !important; animation-duration: .01ms !important; animation-iteration-count: 1 !important; transition-duration: .01ms !important; }
}
